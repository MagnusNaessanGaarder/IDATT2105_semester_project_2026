# Database Configuration (shared between Docker Compose and Spring Boot)

# JDBC URL for Spring Boot (use 127.0.0.1 for VPN, localhost otherwise)
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/internal_control?useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=ik_root
SPRING_DATASOURCE_PASSWORD=ikroot

# MySQL Container Configuration
MYSQL_DATABASE=internal_control
MYSQL_USER=ik_root
MYSQL_PASSWORD=ikroot
MYSQL_ROOT_PASSWORD=root

# JWT Configuration
JWT_SECRET_KEY=

# Server Configuration
SERVER_PORT=8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Azure Blob Storage 
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONNECTION_STRING=

USE_MOCK=false

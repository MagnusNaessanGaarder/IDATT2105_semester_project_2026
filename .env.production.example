# Production Environment Configuration
# Copy this to .env.production and fill in real values
# NEVER commit .env.production to git!

# Database
MYSQL_DATABASE=internal_control
MYSQL_USER=ic_user
MYSQL_PASSWORD=your_secure_password_here
MYSQL_ROOT_PASSWORD=your_secure_root_password_here

# JWT (generate a strong secret)
JWT_SECRET_KEY=your_jwt_secret_at_least_256_bits

# Azure Storage
AZURE_STORAGE_ACCOUNT_KEY=your_azure_key
AZURE_STORAGE_CONNECTION_STRING=your_azure_connection_string

# CORS (add your production domains)
APP_CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

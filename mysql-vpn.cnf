# This is only for users who are on VPN (Tri)
# File wont trigger if you comment out VPN section in compose file
# VPN creates a tunnel thus disturb the network connection between container  (MySQL) and spring-boot (local)

[mysqld]
# Disable SSL for VPN compatibility
require_secure_transport = OFF

# Bind to all interfaces (needed for host network mode)
bind-address = 0.0.0.0

# Increase timeouts for VPN
wait_timeout = 28800
interactive_timeout = 28800

# Connection settings
max_connections = 200
max_connect_errors = 10000
